# ─────────────────────────────────────────────────────────────
# NPC Mixture of Models — environment variables
# Copy to `.env` before running `docker compose up`.
# ─────────────────────────────────────────────────────────────

# HuggingFace (used by both vLLM containers to pull models)
HF_TOKEN=

# MongoDB (API-key auth)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=bottensor
MONGO_COLLECTION=api_keys

# Logging
LOG_LEVEL=INFO

# Dev-only: allow a plaintext test key to bypass Mongo
#   When true, `Authorization: Bearer test-key` is accepted as an enterprise-tier key.
#   LEAVE FALSE IN PRODUCTION.
ALLOW_DEV_KEY=false

# Optional model name overrides (defaults below match production)
# NPC_FAST_MODEL=ramankrishna10/npc-fast-1.7b
# NPC_FIN_MODEL=ramankrishna10/npc-fin-32b-sft
